# Cesium Ion Access Token（可选，用于加载 Cesium World Terrain 3D 地形）
# 在 https://ion.cesium.com 免费注册获取
# VITE_CESIUM_TOKEN=your_token_here

# Cesium Ion 自定义 DEM Asset ID（可选，上传 Copernicus DEM 后使用）
# VITE_CESIUM_TERRAIN_ASSET_ID=your_asset_id

# 天地图中文标注 Token（不填则跳过标注层，不影响地图基础功能）
# 在 https://www.tianditu.gov.cn 注册获取，需绑定域名 localhost
# VITE_TIANDITU_TOKEN=your_tianditu_token

# MapTiler Token — 用于「冬季」底图（MapTiler Winter 冬季地形图）
# 在 https://www.maptiler.com 免费注册，每月 100k 瓦片免费额度
# 不填则「冬季」底图自动回退到 ESRI 地形阴影图
VITE_MAPTILER_TOKEN=YAkTUUHqtKg3V2abYcxA
